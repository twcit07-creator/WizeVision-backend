# Copy this file to .env and fill in your values
# cp .env.example .env

DB_NAME=wizeportal_dev
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_ACCESS_SECRET=generate-a-64-char-random-string-here
JWT_REFRESH_SECRET=generate-a-different-64-char-random-string-here
WINDOWS_ACCESS_SECRET=dev-windows-access-secret-key-min-32-chars-long-abcdefgh
WINDOWS_APP_KEY=your-windows-app-secret-key-here
DB_URL=jdbc:postgresql://localhost:5432/DB_NAME
CORS_ALLOWED_ORIGINS=http://localhost:3000
